# BSC RPC
BSC_RPC_URL=https://bsc-dataseed.binance.org

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Watched Smart Wallets (comma separated addresses)
WATCHED_WALLETS=0x123...,0x456...

# ============================================
# Monitoring Mode Configuration
# ============================================

# Real-time Monitoring Mode (default: true)
# Set to "false" to disable real-time scanning
REALTIME_MODE_ENABLED=true

# Real-time scan interval in seconds (default: 5)
REALTIME_SCAN_INTERVAL=5

# Alert threshold for real-time mode - alert if score >= this value (default: 10)
REALTIME_ALERT_THRESHOLD=10

# Blocks to scan per iteration (default: 100)
REALTIME_BLOCKS_PER_SCAN=100

# Max tokens to process per scan to avoid overload (default: 20)
REALTIME_MAX_TOKENS_PER_SCAN=20

# Summary Report Mode (default: true)
# Set to "false" to disable periodic summary reports
SUMMARY_REPORT_ENABLED=true

# Summary report interval in minutes (default: 30)
SUMMARY_REPORT_INTERVAL=30
